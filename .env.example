# Telegram Bot Token
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ==== AI Provider API Keys ====
# NOTE: These keys are referenced by `provider.toml` via the `api_key_env` field
# on each `[providers.<name>]` block. Only keys whose env var is listed in
# `provider.toml` need to be filled in here. See `provider.toml.example` for
# the full mapping.

# International providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# Domestic (China) providers
# Alibaba Qwen
QWEN_API_KEY=

# Moonshot Kimi
MOONSHOT_API_KEY=

# Zhipu GLM
ZHIPU_API_KEY=

# Baidu ERNIE
BAIDU_API_KEY=
BAIDU_SECRET_KEY=

# ==== Database ====
DATABASE_URL=sqlite+aiosqlite:///telegodex.db

# ==== Redis (Optional) ====
REDIS_URL=redis://localhost:6379

# ==== Security ====
ADMIN_USER_IDS=
MAX_REQUESTS_PER_MINUTE=20
MAX_CONTEXT_MESSAGES=50

# ==== Codex CLI (optional — auto-detected from PATH and common locations) ====
# CODEX_EXECUTABLE_PATH=codex

# ==== Codex Daemon / Approval ====
# CODEX_DAEMON_AUTO_START=True
# CODEX_DAEMON_MAX_RESTARTS=3
# CODEX_APPROVAL_TIMEOUT=60

# NOTE: AI provider selection (default provider / default model / max tokens /
# temperature / streaming / available_providers list) is now configured in
# `provider.toml`. The previous DEFAULT_AI_PROVIDER / DEFAULT_MODEL /
# MAX_TOKENS / TEMPERATURE / CUSTOM_PROVIDERS_CONFIG env vars have been
# removed in favor of the TOML-driven config. See `provider.toml.example`.
