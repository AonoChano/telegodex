# Telegram Bot Token
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ==== 国际 AI Provider API Keys ====
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ==== DeepSeek (2026-04 最新) ====
DEEPSEEK_API_KEY=

# ==== 国内 AI Provider API Keys ====
# 阿里通义千问 (Qwen)
QWEN_API_KEY=

# Moonshot Kimi (2026-06 最新)
MOONSHOT_API_KEY=

# 智谱AI GLM (2026 最新 GLM-4.6)
ZHIPU_API_KEY=

# 百度文心一言 (ERNIE)
BAIDU_API_KEY=
BAIDU_SECRET_KEY=

# ==== 自定义 Provider 配置文件 ====
# 支持任何 OpenAI 兼容 API
# 详见 custom_providers.example.json
CUSTOM_PROVIDERS_CONFIG=custom_providers.json

# ==== Database ====
DATABASE_URL=sqlite+aiosqlite:///telegodex.db

# ==== Redis (可选) ====
REDIS_URL=redis://localhost:6379

# ==== Security ====
ADMIN_USER_IDS=  # 逗号分隔，例如: 123456,789012
MAX_REQUESTS_PER_MINUTE=20
MAX_CONTEXT_MESSAGES=50

# ==== AI Settings ====
DEFAULT_AI_PROVIDER=openai  # openai, anthropic, google, deepseek, qwen, moonshot, zhipu, baidu
DEFAULT_MODEL=gpt-4
MAX_TOKENS=4096
TEMPERATURE=0.7
